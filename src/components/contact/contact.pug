section.contact-section.section-large
	.container
		.row(class="-mt-10")
			.col(class="w-full mt-10 lg:w-5/12")
				.block-content
					h1.site-title
						span Xin chào chúng tôi là
						| CẢNG CẠN PHÚ MỸ
					.contact-info.mt-5
						ul
							li
								i.icon.fa-light.fa-location-dot
								p Trụ sở: KCN Chuyên Sâu Phú Mỹ 3, Phường Phước Hòa, Tỉnh Bà Rịa Vũng Tàu, Việt Nam
							li
								i.icon.fa-light.fa-phone
								p Số điện thoại liên hệ:&nbsp;
									a(href="tel: 097 716 1417") 097 716 1417
							li
								i.icon.fa-light.fa-envelope
								p Email:&nbsp;
									a(href="mailto: sales-pmdryport@phumy3sip.com") sales-pmdryport@phumy3sip.com
					.contact-maps.mt-5
						.iframe-scale.pt-full.is-rounded-tl-s
							<iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4829.178327830393!2d107.06210339936105!3d10.539121948103432!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x317512e5a699dee3%3A0x83af72691c230b5f!2zQ8O0bmcgVHkgQ1AgVGhhbmggQsOsbmggUGjDuiBN4bu5IC0gS0NOIENodXnDqm4gU8OidSBQaMO6IE3hu7kgMw!5e0!3m2!1sen!2s!4v1726045418184!5m2!1sen!2s" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
			.col(class="w-full mt-10 lg:w-7/12")
				.contact-form.bg-neutral-50.is-rounded-tl-s
					form(action="")
						.body-16.font-normal.text-neutral-950.text-center
							p Mọi sự hợp tác tốt đẹp đều bắt đầu từ một cuộc trò chuyện. Hãy liên hệ với chúng tôi, mọi mong muốn của bạn sẽ được lắng nghe.
						.row(class="mt-6")
							.form-group.col(class="w-full mt-4")
								input(type="text" placeholder="Họ và tên")
							.form-group.col(class="w-full mt-4")
								input(type="text" placeholder="Email")
							.form-group.col(class="w-full mt-4")
								input(type="text" placeholder="Số điện thoại")
							.form-group.col(class="w-full mt-4")
								input(type="text" placeholder="Tiêu đề")
							.form-group.col(class="w-full mt-4")
								textarea(placeholder="Nội dung")
							.col(class="w-full mt-10")
								.flex.flex-wrap.items-center.justify-between.gap-5
									.form-group.form-captcha
									.form-group.form-submit
										button.btn-lined
											span Liên hệ tư vấn
											span.icon
												i.fa-solid.fa-arrow-right
												i.fa-solid.fa-arrow-right
