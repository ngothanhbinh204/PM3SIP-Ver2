section.general-banner
	.swiper.banner-top
		.swiper-wrapper
			- for(x=1; x<=5; x++)
				.swiper-slide
					h1.main-title-banner KHU CÔNG NGHIỆP CHUYÊN SÂU PHÚ MỸ 3
					.image.img-cover
						+img(1920, 780)
					.banner-title
						h2.top-banner-title TRUNG TÂM CHUỖI CUNG ỨNG TOÀN CẦU PHÚ MỸ
						h3.bottom-banner-title Hạ tầng tích hợp đa phương thức
	.caption
		.swiper-relative.mt-6
			.swiper.banner-thumbs
				.swiper-wrapper
					- for(x=1; x<=5; x++)
						.swiper-slide
							.image.img-cover
								+img(160, 64)
			.swiper-button
				.button-prev
					i.fa-thin.fa-chevron-left
				.button-next
					i.fa-thin.fa-chevron-right

