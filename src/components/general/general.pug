section.general-banner
	-
		var bannerSlides = [
			{
				banner_title: "KHU CÔNG NGHIỆP CHUYÊN SÂU PHÚ MỸ 3",
				banner_sub_title: "TRUNG TÂM CHUỖI CUNG ỨNG TOÀN CẦU PHÚ MỸ",
				banner_description: "Hạ tầng tích hợp đa phương thức",
				banner_image: { url: "./img/banner-general-1.jpg", alt: "KCN Chuyên sâu Phú Mỹ 3" },
				banner_thumb: { url: "./img/thumb-general-1.jpg", alt: "Thumb 1" }
			},
			{
				banner_title: "KHU CÔNG NGHIỆP CHUYÊN SÂU PHÚ MỸ 3",
				banner_sub_title: "CẢNG BIỂN QUỐC TẾ CÁI MÉP - THỊ VẢI",
				banner_description: "Kết nối hàng hải đa quốc gia",
				banner_image: { url: "./img/banner-general-2.jpg", alt: "Cảng biển quốc tế Cái Mép" },
				banner_thumb: { url: "./img/thumb-general-2.jpg", alt: "Thumb 2" }
			},
			{
				banner_title: "KHU CÔNG NGHIỆP CHUYÊN SÂU PHÚ MỸ 3",
				banner_sub_title: "KHO NGOẠI QUAN VÀ ICD",
				banner_description: "Dịch vụ logistics tích hợp toàn diện",
				banner_image: { url: "./img/banner-general-3.jpg", alt: "Kho ngoại quan và ICD" },
				banner_thumb: { url: "./img/thumb-general-3.jpg", alt: "Thumb 3" }
			},
			{
				banner_title: "KHU CÔNG NGHIỆP CHUYÊN SÂU PHÚ MỸ 3",
				banner_sub_title: "HẠ TẦNG NĂNG LƯỢNG XANH",
				banner_description: "Môi trường đầu tư bền vững",
				banner_image: { url: "./img/banner-general-4.jpg", alt: "Hạ tầng năng lượng xanh" },
				banner_thumb: { url: "./img/thumb-general-4.jpg", alt: "Thumb 4" }
			},
			{
				banner_title: "KHU CÔNG NGHIỆP CHUYÊN SÂU PHÚ MỸ 3",
				banner_sub_title: "DỊCH VỤ XỬ LÝ NƯỚC THẢI CÔNG NGHIỆP",
				banner_description: "Tiêu chuẩn quốc tế ISO 14001",
				banner_image: { url: "./img/banner-general-5.jpg", alt: "Xử lý nước thải công nghiệp" },
				banner_thumb: { url: "./img/thumb-general-5.jpg", alt: "Thumb 5" }
			}
		]
	.swiper.banner-top
		.swiper-wrapper
			each slide in bannerSlides
				.swiper-slide
					h1.main-title-banner= slide.banner_title
					.image.img-cover
						+img(1920, 780)
					.banner-title
						h2.top-banner-title= slide.banner_sub_title
						h3.bottom-banner-title= slide.banner_description
	.caption
		.swiper-relative.mt-6
			.swiper.banner-thumbs
				.swiper-wrapper
					each slide in bannerSlides
						.swiper-slide
							.image.img-cover
								+img(160, 64)
			.swiper-button
				.button-prev
					i.fa-thin.fa-chevron-left
				.button-next
					i.fa-thin.fa-chevron-right

