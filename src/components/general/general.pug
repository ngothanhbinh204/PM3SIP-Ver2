section.general-intro.section-large.full-bleed#gioi-thieu
	.bg-intro(style="background-image: url('./img/bg-ss2.png')")
	.container
		.intro-header
			.sub-title(data-aos="fade-up") GIỚI THIỆU TRUNG TÂM CHUỖI CUNG ỨNG TOÀN CẦU PHÚ MỸ
			h2.site-title.is-white(data-aos="fade-up" data-aos-delay="100") "Thành công của bạn là thành công của chúng tôi"
			.desc(data-aos="fade-up" data-aos-delay="200")
				p Trung tâm chuỗi cung ứng toàn cầu Phú Mỹ đóng vai trò là đầu mối tập kết và trung chuyển hàng hoá chiến lược của khu vực, mang kỳ vọng tạo ra giá trị cộng hưởng mạnh mẽ nhằm đáp ứng nhu cầu phát triển ngày càng tăng của doanh nghiệp và nhà đầu tư
		.intro-stats
				.home-about-item(data-aos="fade-up" data-aos-delay="0")
					.icon.img-contain
						img(src="./img/icon-1.png", alt="")
					.number
						span.count-up(data-count="999") 0
						span ha
					h3.title Diện tích đất khu công nghiệp
				.home-about-item(data-aos="fade-up" data-aos-delay="100")
					.icon.img-contain
						img(src="./img/icon-1.png", alt="")
					.number
						span.count-up(data-count="38") 0
						span ha
					h3.title Diện tích đất khu công nghiệp
				.home-about-item(data-aos="fade-up" data-aos-delay="200")
					.icon.img-contain
						img(src="./img/icon-1.png", alt="")
					.number
						span.count-up(data-count="38") 0
						span ha
					h3.title Diện tích đất khu công nghiệp

section.general-infrastructure.section-large.full-bleed
	.container
		h2.site-title(data-aos="fade-up") Hạ tầng tích hợp đa phương thức
	.infrastructure-list
		- var infraList = ["CẢNG CẠN PHÚ MỸ", "KHO PHÚ MỸ 3", "KHU BỒN CHỨA HÓA CHẤT", "NHÀ MÁY XỬ LÝ NƯỚC THẢI TẬP TRUNG", "TRẠM CUNG CẤP ĐIỆN", "TRẠM CUNG CẤP KHÍ CÔNG NGHIỆP", "TRẠM CUNG CẤP KHÍ TỰ NHIÊN"]
		
		.desktop-view
			.bg-image-list
				each item, index in infraList
					.bg-item(class=(index === 0 ? 'active' : ''))
						+img(1920, 780)
			.items-wrapper.relative.z-10.flex.w-full.h-full
				each item, index in infraList
					.infrastructure-item
						.text-content
							h3.title= item
							.content-wrap
								ul
									li Tổng diện tích: 46 ha
									li Độ sâu cầu cảng: -7 m
									li Tổng chiều dài bến: 600 m
									li Số lượng cầu bến: 06
									li Khả năng tiếp nhận: Tàu SB & sà lan 4,500 DWT/ 200 TEUs
									
		.mobile-view
			.one-slider.infrastructure-mobile-slider
				.swiper
					.swiper-wrapper
						each item, index in infraList
							.swiper-slide
								.mobile-infra-item
									.bg-image
										+img(800, 600)
									.text-content
										h3.title= item
										.content-wrap
											ul
												li Tổng diện tích: 46 ha
												li Độ sâu cầu cảng: -7 m
												li Tổng chiều dài bến: 600 m
												li Số lượng cầu bến: 06
												li Khả năng tiếp nhận: Tàu SB & sà lan 4,500 DWT/ 200 TEUs
				.swiper-pagination.mt-4

