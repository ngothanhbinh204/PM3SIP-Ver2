section.general-certificates.section-large.full-bleed#chung-chi
	.container-full-bleed
		h2.site-title(data-aos="fade-up") Hệ thống chứng chỉ đạt chuẩn quốc tế
		.five-slider.cert-slider-wrapper(data-aos="fade-up" data-aos-delay="100")
			.swiper
				.swiper-wrapper
					-
						var certs = [
							"Giấy chứng nhận quản lý chất lượng ISO 9001:2015",
							"Giấy chứng nhận quản lý môi trường ISO 14001:2015",
							"Giấy chứng nhận ATVSLĐ ISO 45001:2018",
							"Giấy chứng nhận khí nhà kính ISO 14064",
							"Giấy chứng nhận khí nhà kính ISO 14064",
							"Giấy chứng nhận khí nhà kính ISO 14064",
							"Chứng nhận CTPAT Quan hệ Đối tác Thương mại"
						]
					each cert in certs
						.swiper-slide
							.cert-item
								.image.img-contain
									+img(300, 400)
								.title= cert
			.swiper-button
				.button-prev
					i.fa-regular.fa-chevron-left
				.button-next
					i.fa-regular.fa-chevron-right
