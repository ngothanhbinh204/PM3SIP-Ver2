section.section-khophumy-infrastructure.full-bleed.lozad-bg#ha-tang(data-background-image="./img/background_hatang_nangluc.png")
	.container
		.section-khophumy-infrastructure__inner
			h2.section-khophumy-infrastructure__title Hạ tầng và năng lực vận hành
			.bg-svg
					img(src='./img/line_connect_polygon.svg', alt='Cơ sở vật chất')
