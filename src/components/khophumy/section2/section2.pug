section.section-khophumy-warehouse#he-thong-kho
	-
		var section2Data = {
			title: 'Hệ thống kho',
			items: [
				{
					title: 'Kho CFS',
					description: 'Kho ngoại quan tại Cái Mép – Thị Vải có tổng diện tích 15.760 m², trang bị 16 dock leveler hiện đại, tải trọng sàn 5 tấn/m². Hệ thống kệ tiêu chuẩn gồm 11 racks với 22 lines, khả năng lưu trữ hơn 12.000 pallet, sức chứa tối đa 16.000 pallet, tải trọng mỗi pallet 1.000 kg.',
					gallery: [
						{ image: './img/about-2-bg.jpg', alt: 'Kho CFS tại Phú Mỹ' },
						{ image: './img/home-about-bg.jpg', alt: 'Bên trong kho CFS' }
					]
				},
				{
					title: 'Kho Ngoại quan',
					description: 'Kho ngoại quan tại Cái Mép – Thị Vải có tổng diện tích 15.760 m², trang bị 16 dock leveler hiện đại, tải trọng sàn 5 tấn/m². Hệ thống kệ tiêu chuẩn gồm 11 racks với 22 lines, khả năng lưu trữ hơn 12.000 pallet, sức chứa tối đa 16.000 pallet, tải trọng mỗi pallet 1.000 kg.',
					gallery: [
						{ image: './img/about-2-bg.jpg', alt: 'Kho Ngoại quan Phú Mỹ' },
						{ image: './img/home-about-bg.jpg', alt: 'Bên trong kho ngoại quan' },
						{ image: './img/bg_intro_general.png', alt: 'Khu vực kệ hàng ngoại quan' }
					]
				},
				{
					title: 'Kho Tổng hợp',
					description: 'Kho ngoại quan tại Cái Mép – Thị Vải có tổng diện tích 15.760 m², trang bị 16 dock leveler hiện đại, tải trọng sàn 5 tấn/m². Hệ thống kệ tiêu chuẩn gồm 11 racks với 22 lines, khả năng lưu trữ hơn 12.000 pallet, sức chứa tối đa 16.000 pallet, tải trọng mỗi pallet 1.000 kg.',
					gallery: [
						{ image: './img/service-dt-2-bg.jpg', alt: 'Kho Tổng hợp tại Phú Mỹ' },
						{ image: './img/about-2-bg.jpg', alt: 'Không gian kho tổng hợp' }
					]
				},
				{
					title: 'Kho Hoá chất',
					description: 'Kho ngoại quan tại Cái Mép – Thị Vải có tổng diện tích 15.760 m², trang bị 16 dock leveler hiện đại, tải trọng sàn 5 tấn/m². Hệ thống kệ tiêu chuẩn gồm 11 racks với 22 lines, khả năng lưu trữ hơn 12.000 pallet, sức chứa tối đa 16.000 pallet, tải trọng mỗi pallet 1.000 kg.',
					gallery: [
						{ image: './img/about-4-bg.jpg', alt: 'Kho Hoá chất Phú Mỹ' },
						{ image: './img/service-dt-2-bg.jpg', alt: 'Khu vực lưu trữ hoá chất' }
					]
				}
			]
		}
	.bg-kho
		img(src='./img/bg-kho.png', alt='Hệ thống kho tại Phú Mỹ')
	.container
		.section-header
			h2.section-title(data-aos="fade-up")= section2Data.title
		.warehouse-layout
			.warehouse-tab-list(role='list', data-aos="fade-right" data-aos-delay="100")
				each item, index in section2Data.items
					.warehouse-tab-item(class=index === 0 ? 'active' : '', data-index=index, data-target=`#warehouse-gallery-${index}`)
						button.warehouse-tab-btn(type='button', aria-expanded=index === 0 ? 'true' : 'false', aria-controls=`warehouse-gallery-${index}`)
							span.tab-icon(aria-hidden='true')
								<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M31.3371 14.9613L1.62358 1.24733C1.15045 1.03248 0.585894 1.16047 0.25676 1.56732C0.0957054 1.76439 0.00546218 2.00982 0.00048901 2.26428C-0.00448416 2.51874 0.0761006 2.7675 0.229332 2.97071L10.0005 15.999L0.229332 29.0272C-0.0860891 29.4455 -0.0746608 30.0261 0.254474 30.4306C0.476183 30.7072 0.807603 30.8557 1.14359 30.8557C1.30588 30.8557 1.46816 30.8215 1.6213 30.7506L31.3349 17.0367C31.7417 16.8492 32 16.4447 32 15.999C32 15.5533 31.7417 15.1487 31.3371 14.9613Z" fill="currentColor"/></svg>
							span.tab-title= item.title
						if item.description
							.warehouse-tab-desc
								p= item.description
			.warehouse-gallery-list(data-aos="fade-left" data-aos-delay="200")
				each item, index in section2Data.items
					.warehouse-gallery(id=`warehouse-gallery-${index}`, class=index === 0 ? 'active' : '', aria-hidden=index === 0 ? 'false' : 'true')
						.warehouse-slider
							.swiper
								.swiper-wrapper
									each galleryItem in item.gallery
										.swiper-slide
											.slide-image.img-cover
												img(src=galleryItem.image, alt=galleryItem.alt)
						.warehouse-slider-controls
								button.button-prev(type='button', aria-label='Xem ảnh trước')
									i.fa-light.fa-chevron-left
								button.button-next(type='button', aria-label='Xem ảnh tiếp theo')
									i.fa-light.fa-chevron-right
